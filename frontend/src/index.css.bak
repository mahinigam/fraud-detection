@import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Space+Grotesk:wght@300;400;500;600;700&display=swap');
@tailwind base;
@tailwind components;
@tailwind utilities;

/*
  🧊 Black & White Glassmorphic Theme
  Professional Financial AI Console Design
*/

:root {
  /* Glass Effects */
  --glass-bg: rgba(255,255,255,0.05);
  --glass-bg-hover: rgba(255,255,255,0.08);
  --glass-border: rgba(255,255,255,0.1);
  --glass-border-hover: rgba(255,255,255,0.2);
  --glass-shadow: rgba(0,0,0,0.3);
  --glass-glow: rgba(255,255,255,0.15);
  
  /* Typography */
  --text-primary: rgba(255,255,255,0.95);
  --text-secondary: rgba(255,255,255,0.8);
  --text-muted: rgba(255,255,255,0.6);
  --text-disabled: rgba(255,255,255,0.4);
  
  /* Accent Colors */
  --accent-primary: #3B82F6;
  --accent-success: #10B981;
  --accent-warning: #F59E0B;
  --accent-danger: #EF4444;
  
  /* Background Gradients */
  --bg-primary: linear-gradient(135deg, #000000 0%, #0C0C0C 100%);
  --bg-panel: rgba(255,255,255,0.03);
  --bg-card: rgba(255,255,255,0.05);
}

@layer base {
  *, *::before, *::after {
    box-sizing: border-box;
  }

  html, body, #root {
    height: 100%;
    margin: 0;
    padding: 0;
  }

  body {
    background: var(--bg-primary);
    color: var(--text-primary);
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, system-ui, sans-serif;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    text-rendering: optimizeLegibility;
    overflow-x: hidden;
  }

  h1, h2, h3, h4, h5, h6 {
    font-family: 'Space Grotesk', -apple-system, BlinkMacSystemFont, system-ui, sans-serif;
    font-weight: 600;
    line-height: 1.2;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  input, select, textarea {
    font-family: inherit;
  }

  button {
    font-family: inherit;
    cursor: pointer;
  }
}

/* 🎭 Keyframe Animations */
@keyframes fadeIn {
  from { opacity: 0; transform: translateY(20px); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes slideIn {
  from { opacity: 0; transform: translateX(-20px); }
  to { opacity: 1; transform: translateX(0); }
}

@keyframes glow {
  0%, 100% { box-shadow: 0 0 20px rgba(255,255,255,0.1); }
  50% { box-shadow: 0 0 40px rgba(255,255,255,0.2); }
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.7; }
}

@keyframes shimmer {
  0% { transform: translateX(-100%); }
  100% { transform: translateX(100%); }
}

@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

@layer components {
  /* 🧊 Core Glass Components */
  .glass-panel {
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-radius: 16px;
    box-shadow: 
      0 8px 32px var(--glass-shadow),
      inset 0 1px 0 rgba(255,255,255,0.1);
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    position: relative;
    overflow: hidden;
  }

  .glass-panel:hover {
    background: var(--glass-bg-hover);
    border-color: var(--glass-border-hover);
    box-shadow: 
      0 12px 48px var(--glass-shadow),
      inset 0 1px 0 rgba(255,255,255,0.15);
  }

  /* 🎛️ Layout Components */
  .app-layout {
    height: 100vh;
    display: grid;
    grid-template-columns: 280px 1fr 350px;
    gap: 24px;
    padding: 24px;
    background: var(--bg-primary);
    overflow: hidden;
  }

  .sidebar {
    background: var(--bg-panel);
    border: 1px solid var(--glass-border);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-radius: 20px;
    padding: 24px;
    position: relative;
    overflow-y: auto;
  }

  .main-panel {
    background: var(--bg-card);
    border: 1px solid var(--glass-border);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-radius: 20px;
    padding: 32px;
    overflow-y: auto;
    display: flex;
    flex-direction: column;
  }

  .result-panel {
    background: var(--bg-card);
    border: 1px solid var(--glass-border);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-radius: 20px;
    padding: 24px;
    overflow-y: auto;
  }

  /* 📱 Responsive Layout */
  @media (max-width: 1024px) {
    .app-layout {
      grid-template-columns: 1fr;
      grid-template-rows: auto 1fr auto;
      gap: 16px;
      padding: 16px;
    }
    
    .sidebar {
      order: 1;
      padding: 16px;
    }
    
    .main-panel {
      order: 2;
      padding: 24px;
    }
    
    .result-panel {
      order: 3;
      padding: 16px;
    }
  }

  /* 🎯 Navigation Styles */
  .nav-item {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 16px;
    border-radius: 12px;
    color: var(--text-secondary);
    transition: all 0.2s ease;
    margin-bottom: 8px;
    position: relative;
  }

  .nav-item:hover {
    background: rgba(255,255,255,0.1);
    color: var(--text-primary);
  }

  .nav-item.active {
    background: var(--accent-primary);
    color: white;
    box-shadow: 0 4px 16px rgba(59,130,246,0.3);
  }

  .nav-item.active::before {
    content: '';
    position: absolute;
    left: -4px;
    top: 50%;
    transform: translateY(-50%);
    width: 3px;
    height: 24px;
    background: white;
    border-radius: 2px;
  }
}

@media (prefers-color-scheme: light) {
  :root {
    --glass-bg: rgba(255,255,255,0.8);
    --glass-border: rgba(0,0,0,0.06);
    --glass-shadow: rgba(0,0,0,0.08);
    --text-color: #0f172a;
    --muted: rgba(0,0,0,0.56);
  }

  @layer base {
    body {
      background-color: #ffffff;
      color: #0f172a;
    }
  }
}

  /* 📝 Form Styles */
  .form-section {
    margin-bottom: 32px;
  }

  .section-header {
    font-size: 24px;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 24px;
    position: relative;
    padding-bottom: 12px;
  }

  .section-header::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 60px;
    height: 3px;
    background: linear-gradient(90deg, var(--accent-primary), transparent);
    border-radius: 2px;
  }

  .form-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
    margin-bottom: 24px;
  }

  @media (max-width: 768px) {
    .form-grid {
      grid-template-columns: 1fr;
      gap: 16px;
    }
  }

  .form-field {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .field-label {
    font-size: 14px;
    font-weight: 500;
    color: var(--text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.5px;
    transition: color 0.2s ease;
  }

  .field-input {
    background: rgba(255,255,255,0.05);
    border: 1px solid var(--glass-border);
    border-radius: 12px;
    padding: 14px 16px;
    color: var(--text-primary);
    font-size: 16px;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }

  .field-input::placeholder {
    color: var(--text-muted);
  }

  .field-input:hover {
    background: rgba(255,255,255,0.08);
    border-color: var(--glass-border-hover);
    box-shadow: 0 4px 16px rgba(255,255,255,0.1);
  }

  .field-input:focus {
    outline: none;
    background: rgba(255,255,255,0.1);
    border-color: var(--accent-primary);
    box-shadow: 
      0 0 0 3px rgba(59,130,246,0.1),
      0 8px 24px rgba(0,0,0,0.2);
  }

  .field-input:focus + .field-label,
  .field-input:not(:placeholder-shown) + .field-label {
    color: var(--accent-primary);
  }

  .select-input {
    appearance: none;
    background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' fill='none' viewBox='0 0 20 20'%3e%3cpath stroke='%239ca3af' stroke-linecap='round' stroke-linejoin='round' stroke-width='1.5' d='m6 8 4 4 4-4'/%3e%3c/svg%3e");
    background-position: right 12px center;
    background-repeat: no-repeat;
    background-size: 16px;
    padding-right: 40px;
  }

  .select-input option {
    background: #1a1a1a;
    color: var(--text-primary);
    padding: 12px;
  }

  /* 🎛️ Button Styles */
  .btn-row {
    display: flex;
    gap: 16px;
    margin-top: 32px;
    flex-wrap: wrap;
  }

  .btn {
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    border-radius: 12px;
    padding: 14px 24px;
    color: var(--text-primary);
    font-weight: 500;
    font-size: 14px;
    cursor: pointer;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    position: relative;
    overflow: hidden;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .btn::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.1), transparent);
    transition: left 0.6s;
  }

  .btn:hover::before {
    left: 100%;
  }

  .btn:hover {
    background: var(--glass-bg-hover);
    border-color: var(--glass-border-hover);
    box-shadow: 0 8px 32px rgba(255,255,255,0.1);
    transform: translateY(-2px);
  }

  .btn-primary {
    background: var(--accent-primary);
    border-color: var(--accent-primary);
    color: white;
    font-weight: 600;
  }

  .btn-primary:hover {
    background: #2563eb;
    box-shadow: 0 12px 40px rgba(59,130,246,0.4);
  }

  .btn-secondary {
    background: rgba(255,255,255,0.1);
    border-color: rgba(255,255,255,0.2);
  }

  .btn-ghost {
    background: transparent;
    border-color: var(--glass-border);
    color: var(--text-secondary);
  }

  .btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
    pointer-events: none;
  }

  /* 📊 Result Panel Styles */
  .risk-display {
    text-align: center;
    padding: 24px;
    margin-bottom: 24px;
  }

  .risk-score {
    font-size: 48px;
    font-weight: 700;
    background: linear-gradient(135deg, var(--text-primary), var(--accent-primary));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin: 16px 0;
  }

  .risk-indicator {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 16px;
    border-radius: 24px;
    font-weight: 600;
    font-size: 14px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .risk-low { 
    background: rgba(16,185,129,0.2); 
    border: 1px solid rgba(16,185,129,0.4);
    color: var(--accent-success);
  }

  .risk-medium { 
    background: rgba(245,158,11,0.2); 
    border: 1px solid rgba(245,158,11,0.4);
    color: var(--accent-warning);
  }

  .risk-high { 
    background: rgba(239,68,68,0.2); 
    border: 1px solid rgba(239,68,68,0.4);
    color: var(--accent-danger);
  }

  .progress-container {
    background: rgba(255,255,255,0.1);
    border-radius: 8px;
    height: 12px;
    margin: 16px 0;
    overflow: hidden;
  }

  .progress-bar {
    height: 100%;
    background: linear-gradient(90deg, var(--accent-success), var(--accent-warning), var(--accent-danger));
    border-radius: inherit;
    transition: width 1s cubic-bezier(0.4, 0, 0.2, 1);
    position: relative;
  }

  .progress-bar::after {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.4), transparent);
    animation: shimmer 2s infinite;
  }

/* Utility helpers */
.glass-outline {
  outline: 1px solid transparent;
}

.flex {
  display: flex;
}

.items-center {
  align-items: center;
}

.justify-center {
  justify-content: center;
}

.mb-4 {
  margin-bottom: 1rem;
}

.mb-6 {
  margin-bottom: 1.5rem;
}

  /* 🔍 Details Panel */
  .detail-card {
    background: rgba(255,255,255,0.03);
    border: 1px solid var(--glass-border);
    border-radius: 12px;
    padding: 20px;
    margin-bottom: 16px;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }

  .detail-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 12px 0;
    border-bottom: 1px solid rgba(255,255,255,0.05);
  }

  .detail-row:last-child {
    border-bottom: none;
  }

  .detail-label {
    color: var(--text-secondary);
    font-size: 14px;
    font-weight: 500;
  }

  .detail-value {
    color: var(--text-primary);
    font-weight: 600;
    font-size: 14px;
  }

  /* 📱 Loading States */
  .loading-spinner {
    width: 20px;
    height: 20px;
    border: 2px solid rgba(255,255,255,0.3);
    border-top: 2px solid var(--text-primary);
    border-radius: 50%;
    animation: spin 1s linear infinite;
  }

  .pulse-dot {
    width: 8px;
    height: 8px;
    background: var(--accent-primary);
    border-radius: 50%;
    animation: pulse 2s infinite;
  }

  /* 🎨 Utility Classes */
  .text-gradient {
    background: linear-gradient(135deg, var(--text-primary), var(--accent-primary));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .glow-effect {
    animation: glow 2s ease-in-out infinite alternate;
  }

  .fade-in {
    animation: fadeIn 0.6s ease-out;
  }

  .slide-in {
    animation: slideIn 0.4s ease-out;
  }
}

/* Enhanced loading animations */
.loading-pulse {
  animation: pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
}

/* Interactive micro-animations */
.glass-panel:hover .section-header {
  text-shadow: 0 0 20px rgba(255,255,255,0.3);
}

.btn:hover {
  letter-spacing: 0.02em;
}

/* Light mode adjustments */
@media (prefers-color-scheme: light) {
  .field-input option {
    background: #ffffff;
    color: #1f2937;
  }
  
  .loading-spinner {
    border-color: rgba(0,0,0,0.3);
    border-top-color: #1f2937;
  }
}